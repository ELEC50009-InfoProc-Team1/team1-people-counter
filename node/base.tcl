# Hierarchical cell: morphological_open
proc create_hier_cell_morphological_open { parentCell nameHier } {

  variable script_folder

  if { $parentCell eq "" || $nameHier eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2092 -severity "ERROR" "create_hier_cell_morphological_open() - Empty argument(s)!"}
     return
  }

  # Get object for parentCell
  set parentObj [get_bd_cells $parentCell]
  if { $parentObj == "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2090 -severity "ERROR" "Unable to find parent cell <$parentCell>!"}
     return
  }

  # Make sure parentObj is hier blk
  set parentType [get_property TYPE $parentObj]
  if { $parentType ne "hier" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2091 -severity "ERROR" "Parent <$parentObj> has TYPE = <$parentType>. Expected to be <hier>."}
     return
  }

  # Save current instance; Restore later
  set oldCurInst [current_bd_instance .]

  # Set parent object as current
  current_bd_instance $parentObj

  # Create cell and set as current instance
  set hier_obj [create_bd_cell -type hier $nameHier]
  current_bd_instance $hier_obj

  # Create interface pins
  create_bd_intf_pin -mode Slave -vlnv xilinx.com:interface:aximm_rtl:1.0 s_axi_control

  create_bd_intf_pin -mode Slave -vlnv xilinx.com:interface:aximm_rtl:1.0 s_axi_control1

  create_bd_intf_pin -mode Slave -vlnv xilinx.com:interface:axis_rtl:1.0 stream_in

  create_bd_intf_pin -mode Master -vlnv xilinx.com:interface:axis_rtl:1.0 stream_out


  # Create pins
  create_bd_pin -dir I -type rst ap_rst_n
  create_bd_pin -dir I -type clk clk_100M

  # Create instance: morphological_dilati_0, and set properties
  set morphological_dilati_0 [ create_bd_cell -type ip -vlnv xilinx.com:hls:morphological_dilation:1.0 morphological_dilati_0 ]

  # Create instance: morphological_erosion_0, and set properties
  set morphological_erosion_0 [ create_bd_cell -type ip -vlnv xilinx.com:hls:morphological_erosion:1.0 morphological_erosion_0 ]

  # Create interface connections
  connect_bd_intf_net -intf_net Conn1 [get_bd_intf_pins s_axi_control] [get_bd_intf_pins morphological_erosion_0/s_axi_control]
  connect_bd_intf_net -intf_net Conn2 [get_bd_intf_pins s_axi_control1] [get_bd_intf_pins morphological_dilati_0/s_axi_control]
  connect_bd_intf_net -intf_net downscale_2x_0_stream_out [get_bd_intf_pins stream_in] [get_bd_intf_pins morphological_erosion_0/stream_in]
  connect_bd_intf_net -intf_net morphological_dilati_0_stream_out [get_bd_intf_pins stream_out] [get_bd_intf_pins morphological_dilati_0/stream_out]
  connect_bd_intf_net -intf_net morphological_erosion_0_stream_out [get_bd_intf_pins morphological_dilati_0/stream_in] [get_bd_intf_pins morphological_erosion_0/stream_out]

  # Create port connections
  connect_bd_net -net Net [get_bd_pins clk_100M] [get_bd_pins morphological_dilati_0/ap_clk] [get_bd_pins morphological_erosion_0/ap_clk]
  connect_bd_net -net Net2 [get_bd_pins ap_rst_n] [get_bd_pins morphological_dilati_0/ap_rst_n] [get_bd_pins morphological_erosion_0/ap_rst_n]

  # Restore current instance
  current_bd_instance $oldCurInst
}
  
